#include <xc.h>

volatile unsigned int c = 0;
volatile unsigned char s = 0;

/*
s = 0 -> Red
s = 1 -> Yellow
s = 2 -> Green
*/

void __interrupt() ISR(void)
{
    if(T0IF)
    {
        T0IF = 0;

        c++;

        switch(s)
        {
            case 0: // Red for 5 sec
                if(c >= 305)
                {
                    c = 0;
                    s = 1;
                }
                break;

            case 1: // Yellow for 3 sec
                if(c >= 183)
                {
                    c = 0;
                    s = 2;
                }
                break;

            case 2: // Green for 5 sec
                if(c >= 305)
                {
                    c = 0;
                    s = 0;
                }
                break;
        }

        // Traffic Light A (RB0,RB1,RB2)
        if(s == 0)
        {
            RB0 = 1; RB1 = 0; RB2 = 0;
        }
        else if(s == 1)
        {
            RB0 = 0; RB1 = 1; RB2 = 0;
        }
        else
        {
            RB0 = 0; RB1 = 0; RB2 = 1;
        }
    }
}

void main()
{
    TRISB = 0x00;
    PORTB = 0x00;

    OPTION_REG = 0x07; // Timer0 prescaler 1:256
    T0IE = 1;
    GIE = 1;

    while(1)
    {
        // Traffic Light B (RB3,RB4,RB5)

        if(s == 0) // A=Red => B=Green
        {
            RB3 = 0;
            RB4 = 0;
            RB5 = 1;
        }
        else if(s == 1) // A=Yellow => B=Red
        {
            RB3 = 0;
            RB4 = 1;
            RB5 = 0;
        }
        else // A=Green => B=Red
        {
            RB3 = 1;
            RB4 = 0;
            RB5 = 0;
        }
    }
}
