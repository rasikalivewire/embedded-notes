#include <xc.h>
#include <string.h>

// Configuration Bits
#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = ON
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 8000000 

// Pin Definitions
#define RS RD2
#define EN RD3
#define D4 RD4
#define D5 RD5
#define D6 RD6
#define D7 RD7

#define BUZZER RC0
#define ALARM_LED RC1
#define SERVO RC2
#define ADMIN_BTN RA0

const char ROOT_PASS[] = "999999"; 

// --- LCD Driver Functions ---
void Lcd_Port(char a) {
    if(a & 1) D4 = 1; else D4 = 0;
    if(a & 2) D5 = 1; else D5 = 0;
    if(a & 4) D6 = 1; else D6 = 0;
    if(a & 8) D7 = 1; else D7 = 0;
}
void Lcd_Cmd(char a) {
    RS = 0; Lcd_Port(a >> 4); EN = 1; __delay_ms(1); EN = 0;
    Lcd_Port(a); EN = 1; __delay_ms(1); EN = 0;
}
void Lcd_Write_Char(char a) {
    RS = 1; Lcd_Port(a >> 4); EN = 1; __delay_ms(1); EN = 0;
    Lcd_Port(a); EN = 1; __delay_ms(1); EN = 0;
}
void Lcd_Write_String(char *a) {
    for(int i=0; a[i]!='\0'; i++) Lcd_Write_Char(a[i]);
}
void Lcd_Set_Cursor(char row, char col) {
    char temp;
    if(row == 1) temp = 0x80 + col - 1;
    else if(row == 2) temp = 0xC0 + col - 1;
    Lcd_Cmd(temp);
}
void Lcd_Init() {
    Lcd_Port(0x00); __delay_ms(20);
    Lcd_Cmd(0x03); __delay_ms(5);
    Lcd_Cmd(0x03); __delay_ms(11);
    Lcd_Cmd(0x03); Lcd_Cmd(0x02);
    Lcd_Cmd(0x28); Lcd_Cmd(0x0C); 
    Lcd_Cmd(0x06); Lcd_Cmd(0x01);
}

// --- Keypad Function ---
char Get_Key() {
    while(1) {
        RB0 = 0; RB1 = 1; RB2 = 1; RB3 = 1; // Row 1
        if (RB4 == 0) { __delay_ms(20); while(RB4==0); return '1'; }
        if (RB5 == 0) { __delay_ms(20); while(RB5==0); return '2'; }
        if (RB6 == 0) { __delay_ms(20); while(RB6==0); return '3'; }

        RB0 = 1; RB1 = 0; RB2 = 1; RB3 = 1; // Row 2
        if (RB4 == 0) { __delay_ms(20); while(RB4==0); return '4'; }
        if (RB5 == 0) { __delay_ms(20); while(RB5==0); return '5'; }
        if (RB6 == 0) { __delay_ms(20); while(RB6==0); return '6'; }

        RB0 = 1; RB1 = 1; RB2 = 0; RB3 = 1; // Row 3
        if (RB4 == 0) { __delay_ms(20); while(RB4==0); return '7'; }
        if (RB5 == 0) { __delay_ms(20); while(RB5==0); return '8'; }
        if (RB6 == 0) { __delay_ms(20); while(RB6==0); return '9'; }

        RB0 = 1; RB1 = 1; RB2 = 1; RB3 = 0; // Row 4
        if (RB4 == 0) { __delay_ms(20); while(RB4==0); return '*'; }
        if (RB5 == 0) { __delay_ms(20); while(RB5==0); return '0'; }
        if (RB6 == 0) { __delay_ms(20); while(RB6==0); return '#'; }
        
        // Break out if admin button is pressed during keypad wait
        // Break out if admin button is pressed during keypad wait
        if(ADMIN_BTN == 0) {
            __delay_ms(50);          // Debounce to ignore switch noise
            while(ADMIN_BTN == 0);   // WAIT HERE until the button is released
            return 'A'; 
        }
    }
}

// --- Servo Control ---
void Open_Safe() {
    for(int i=0; i<50; i++) { // 1 sec generation of 50Hz PWM
        SERVO = 1; __delay_us(1500); // 1.5ms pulse (90 deg)
        SERVO = 0; __delay_us(18500); 
    }
}

void Close_Safe() {
    for(int i=0; i<50; i++) {
        SERVO = 1; __delay_us(1000); // 1.0ms pulse (0 deg)
        SERVO = 0; __delay_us(19000);
    }
}

// --- Main Program ---
void main() {
    char entered_pass[5];
    char eeprom_pass[5];
    char admin_entry[7];
    int attempts = 0;

    // I/O Setup
    ADCON1 = 0x06;            // Make PORTA digital
    TRISA = 0x01;             // RA0 as input (Admin Button)
    TRISB = 0xF0;             // RB0-3 out, RB4-7 in (Keypad)
    OPTION_REGbits.nRBPU = 0; // Enable PORTB internal pull-ups
    TRISC = 0x00;             // PORTC as output (Alerts & Servo)
    TRISD = 0x00;             // PORTD as output (LCD)
    
    BUZZER = 0; ALARM_LED = 0; SERVO = 0;
    Lcd_Init();

    // Check EEPROM initialization
    if (eeprom_read(0) == 0xFF) { 
        // First boot: set default password "1234"
        eeprom_write(0, '1'); eeprom_write(1, '2');
        eeprom_write(2, '3'); eeprom_write(3, '4');
    }

    Close_Safe(); // Ensure safe is locked on boot

    while(1) {
        Lcd_Cmd(0x01);
        Lcd_Set_Cursor(1, 1);
        Lcd_Write_String("Enter Password:");
        Lcd_Set_Cursor(2, 1);

        // Fetch Password from EEPROM
        for(int i=0; i<4; i++) {
            eeprom_pass[i] = eeprom_read(i);
        }
        eeprom_pass[4] = '\0';

        // Read 4 digits from user
        for(int i=0; i<4; i++) {
            char key = Get_Key();
            
            // Handle Secret Admin Menu Interception
            if (key == 'A') {
                Lcd_Cmd(0x01);
                Lcd_Set_Cursor(1, 1);
                Lcd_Write_String("ROOT PASS:");
                Lcd_Set_Cursor(2, 1);
                for(int j=0; j<6; j++) {
                    admin_entry[j] = Get_Key();
                    Lcd_Write_Char('*');
                }
                admin_entry[6] = '\0';
                
                if(strcmp(admin_entry, ROOT_PASS) == 0) {
                    Lcd_Cmd(0x01);
                    Lcd_Set_Cursor(1, 1);
                    Lcd_Write_String("NEW 4-DIGIT PIN:");
                    Lcd_Set_Cursor(2, 1);
                    for(int j=0; j<4; j++) {
                        char new_key = Get_Key();
                        eeprom_write(j, new_key);
                        Lcd_Write_Char(new_key);
                    }
                    Lcd_Cmd(0x01);
                    Lcd_Set_Cursor(1, 1);
                    Lcd_Write_String("PIN UPDATED!");
                    __delay_ms(2000);
                } else {
                    Lcd_Cmd(0x01);
                    Lcd_Set_Cursor(1, 1);
                    Lcd_Write_String("ACCESS DENIED");
                    __delay_ms(2000);
                }
                goto RESET_LOOP; // Jump out to restart main loop
            }

            entered_pass[i] = key;
            Lcd_Write_Char('*'); 
        }
        entered_pass[4] = '\0';

        // Check Password Match
        if(strcmp(entered_pass, eeprom_pass) == 0) {
            attempts = 0; // Reset attempts
            Lcd_Cmd(0x01);
            Lcd_Set_Cursor(1, 1);
            Lcd_Write_String("ACCESS GRANTED");
            Open_Safe();
            __delay_ms(3000); // Keep safe open for 3 seconds
            Close_Safe();
        } else {
            attempts++;
            Lcd_Cmd(0x01);
            Lcd_Set_Cursor(1, 1);
            Lcd_Write_String("WRONG PIN!");
            __delay_ms(1500);

            if(attempts >= 3) {
                Lcd_Cmd(0x01);
                Lcd_Set_Cursor(1, 1);
                Lcd_Write_String("SYSTEM LOCKED!");
                
                // Infinite alarm loop. Requires hardware reset to clear.
                while(1) {
                    ALARM_LED = 1;
                    BUZZER = 1;
                    __delay_ms(200);
                    ALARM_LED = 0;
                    BUZZER = 0;
                    __delay_ms(200);
                }
            }
        }
        RESET_LOOP: continue;
    }
}
