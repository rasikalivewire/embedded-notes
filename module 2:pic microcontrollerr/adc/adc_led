/*
 *==============================================================================
 * File        : main.c
 * Controller  : PIC16F877A
 * Compiler    : XC8
 * IDE         : MPLAB X IDE
 *
 * Description :
 * --------------
 * 1. Read ADC channels AN0, AN1 and AN2 once every 5 seconds.
 * 2. Convert ADC values into percentage.
 * 3. If any one or any two channels are below 50%, blink Yellow LED.
 * 4. If all three channels are below 50%, blink Red LED.
 * 5. If all are above or equal to 50%, turn OFF both LEDs.
 *
 * Connections
 * -----------
 * AN0 -> RA0
 * AN1 -> RA1
 * AN2 -> RA2
 *
 * Yellow LED -> RB0
 * Red LED    -> RB1
 *
 * Crystal : 20 MHz
 *==============================================================================
 */

#include <xc.h>

#define _XTAL_FREQ 20000000

// Configuration Bits
#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = ON
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define YELLOW_LED PORTBbits.RB0
#define RED_LED    PORTBbits.RB1

unsigned int ADC_Read(unsigned char c);
void ADC_Init(void);
void BlinkYellow(void);
void BlinkRed(void);

void main()
{
    unsigned int a;
    unsigned int b;
    unsigned int c;

    unsigned char p1;
    unsigned char p2;
    unsigned char p3;

    unsigned char x;

    TRISA = 0xFF;
    TRISB = 0x00;

    PORTB = 0x00;

    ADC_Init();

    while(1)
    {
        //-------------------------
        // Wait for 5 seconds
        //-------------------------
        __delay_ms(1000);
        __delay_ms(1000);
        __delay_ms(1000);
        __delay_ms(1000);
        __delay_ms(1000);

        //-------------------------
        // Read ADC
        //-------------------------
        a = ADC_Read(0);
        b = ADC_Read(1);
        c = ADC_Read(2);

        //-------------------------
        // Convert to Percentage
        //-------------------------
        p1 = (a * 100) / 1023;
        p2 = (b * 100) / 1023;
        p3 = (c * 100) / 1023;

        //-------------------------
        // Count channels below 50%
        //-------------------------
        x = 0;

        if(p1 < 50)
            x++;

        if(p2 < 50)
            x++;

        if(p3 < 50)
            x++;

        //-------------------------
        // Decision
        //-------------------------
        if(x == 3)
        {
            BlinkRed();
        }
        else if(x == 1 || x == 2)
        {
            BlinkYellow();
        }
        else
        {
            RED_LED = 0;
            YELLOW_LED = 0;
        }
    }
}

/*----------------------------------------------------
                ADC Initialization
----------------------------------------------------*/
void ADC_Init(void)
{
    ADCON0 = 0x41;      // ADC ON, Channel AN0
    ADCON1 = 0x80;      // Right Justified, Fosc/32
}

/*----------------------------------------------------
                ADC Read Function
----------------------------------------------------*/
unsigned int ADC_Read(unsigned char c)
{
    ADCON0 &= 0xC7;         // Clear channel bits
    ADCON0 |= (c << 3);     // Select channel

    __delay_ms(2);

    GO_nDONE = 1;

    while(GO_nDONE);

    return ((ADRESH << 8) | ADRESL);
}

/*----------------------------------------------------
          Blink Yellow LED for 5 Seconds
----------------------------------------------------*/
void BlinkYellow(void)
{
    unsigned char i;

    RED_LED = 0;

    for(i=0;i<10;i++)
    {
        YELLOW_LED = 1;
        __delay_ms(250);

        YELLOW_LED = 0;
        __delay_ms(250);
    }
}

/*----------------------------------------------------
           Blink Red LED for 5 Seconds
----------------------------------------------------*/
void BlinkRed(void)
{
    unsigned char i;

    YELLOW_LED = 0;

    for(i=0;i<10;i++)
    {
        RED_LED = 1;
        __delay_ms(250);

        RED_LED = 0;
        __delay_ms(250);
    }
}
